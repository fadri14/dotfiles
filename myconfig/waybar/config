{
    "layer": "top",
        "position": "top",
        "spacing": 10,
        "modules-left": ["clock", "pulseaudio", "backlight", "mpd", "sway/mode"],
        "modules-center": ["sway/workspaces"],
        "modules-right": ["network", "tray", "memory", "cpu", "battery"],
        "sway/workspaces": {
            "format": "{icon}"
        },
        "mpd": {
            "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon} {elapsedTime:%M:%S}/{totalTime:%M:%S} έ╕ρ{songPosition}|{queueLength}έ╕σ {volume}% ΎΑΒ",
            // "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) έ╕ρ{songPosition}|{queueLength}έ╕σ {volume}% ΎΑΒ",
            "format-disconnected": "Disconnected ΎΑΒ",
            "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon} Stopped ΎΑΒ",
            "unknown-tag": "N/A",
            "interval": 2,
            "consume-icons": {
                "on": "ΎΔΕ "
            },
            "random-icons": {
                //"off": "<span color=\"#f53c3c\">ΎΒ┤</span> ",
                "on": "ΎΒ┤ "
            },
            "repeat-icons": {
                "on": "ΎΑη "
            },
            "single-icons": {
                "on": "ΎΑη1 "
            },
            "state-icons": {
                "paused": "ΎΒΝ",
                "playing": "ΎΒΜ"
            },
            "tooltip-format": "Sound: {title}",
            "tooltip-format-disconnected": "MPD (disconnected)",
            "on-click": "mpc toggle",
            "on-double-click": "mpc next",
            "on-click-right": "mpc seek 00:00:00",
            "on-double-click-right": "mpc prev"
        },
        "clock": {
            "format": "{:%H:%M} ΎΑΩ",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
            "format-alt": "{:%d-%m-%Y}"
        },
        "pulseaudio": {
            "scroll-step": 5, // %, can be a float
            "format": "{volume}% {icon} {format_source}",
            "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
            "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
            "format-muted": "≤░ζθ {format_source}",
            "format-source": " {volume}% ΎΕ░",
            "format-source-muted": "ΎΕ▒",
            "format-icons": {
                "headphone": "ΎΑξ",
                "hands-free": "ΎΨΡ",
                "headset": "ΎΨΡ",
                "phone": "ΎΓΧ",
                "portable": "ΎΓΧ",
                "car": "ΎΗ╣",
                "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
            },
            "on-click": "pavucontrol",
            "on-click-right": "amixer set Capture toggle"
        },
        "backlight": {
            // "device": "acpi_video1",
            "format": "{percent}% {icon}",
            "format-icons": ["ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
            "on-click": "/home/adrien/.config/myscripts/switch_gamma",
        },
        "network": {
            "format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
            "format-ethernet": "{ipaddr}/{cidr} ≤░ΙΒ",
            "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
            "format-linked": "{ifname} (No IP) ΎηΨ",
            "format-disconnected": "Disconnected έγι",
            "format-alt": "{ifname}: {ipaddr}/{cidr}"
        },
        "memory": {
            "interval": 10,
            "format": "{percentage}% ΎΔΚ  {swapPercentage}% ≤░╛┤",
            "format-alt": "{used:0.2f} ΎΔΚ  {swapUsed:0.2f} ≤░╛┤",
            "states": {
                "warning": 70,
                "critical": 90
            },
            "tooltip": false
        },
        "cpu": {
            "interval": 10,
            "format": "{usage}% ΎΜδ  {avg_frequency} ≤░ΥΖ",
            "tooltip": false,
        },
        "battery": {
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 15
            },
            "format": "{capacity}% {icon}",
            "format-charging": "{capacity}% ≤░ΓΕ",
            "format-plugged": "{capacity}% ΎΘο",
            "format-alt": "{time} {icon}",
            "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
            "interval" : 60
        }
}
