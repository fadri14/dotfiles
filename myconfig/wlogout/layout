{
    "label" : "poweroff",
    "action" : "systemctl poweroff",
    "text" : "Poweroff",
    "keybind" : "p"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend",
    "keybind" : "s"
}
{
    "label" : "logout",
    "action" : "niri msg action quit --skip-confirmation",
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "lock",
    "action" : "gtklock -S -s ~/.config/gtklock/style.css -b ~/.config/sway/Images/Cfallaisechinoise.png -t '%T' --date-format '%A, %d/%m/%Y'",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "hibernate",
    "action" : "systemctl hibernate",
    "text" : "Hibernate",
    "keybind" : "h"
}
