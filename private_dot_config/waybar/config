{
    "layer": "top",
	"position": "top",
	"height": "",
	"width": "",
	"margin": "3",
	"spacing": "25",
	"reload_style_on_change": true,

    "modules-left": ["backlight", "pulseaudio", "tray"],
    "modules-center": ["clock"],
    "modules-right": ["memory", "cpu", "battery"],

    "clock": {
        "format": "{:%H:%M ΎΑΩ  | %a | %d/%m ΎΒ│}",
        //"format": "{:%H:%M ΎΑΩ  - %d/%m ΎΒ│}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "year",
                    "mode-mon-col"  : 3,
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#ffead3'><b>{}</b></span>",
                              "days":       "<span color='#ffffff'><b>{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    }
    },
    "pulseaudio": {
        "scroll-step": 5, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "≤░ζθ {format_source}",
        "format-source": " {volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pwvucontrol",
        "on-click-right": "amixer set Capture toggle"
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
        "on-click": "/home/adrien/.config/myscripts/switch_gamma",
    },
    "memory": {
        "interval": 10,
        "format": "{percentage}% ΎΔΚ  {swapPercentage}% ≤░╛┤",
        "format-alt": "{used:0.2f} ΎΔΚ  {swapUsed:0.2f} ≤░╛┤",
    },
    "cpu": {
        "interval": 10,
        "format": "{usage}% ΎΜδ  {avg_frequency} ≤░ΥΖ",
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ≤░ΓΕ",
        "format-plugged": "{capacity}% ΎΘο",
        "format-alt": "{time} {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "interval" : 60
    },
}
